rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (matches request.auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - totalPoints: number (required, >= 0)
    //   - level: number (optional, >= 1)
    //   - lastUpdated: timestamp (required)
    //
    // Collection: drill_attempts
    // Document ID: attemptId
    // Fields:
    //   - uid: string (required, matches request.auth.uid)
    //   - drillId: string (required)
    //   - successRate: number (required, 0-100)
    //   - pointsEarned: number (required, >= 0)
    //   - isPersonalBest: bool (optional)
    //   - timestamp: timestamp (required)
    //
    // Collection: quiz_results
    // Document ID: resultId
    // Fields:
    //   - uid: string (required, matches request.auth.uid)
    //   - score: number (required, >= 0)
    //   - totalQuestions: number (required, > 0)
    //   - pointsEarned: number (required, >= 0)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    //
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    //
    // Check if user owns the resource (for user-owned documents)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    //
    // Check if user is owner based on document's uid field
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    //
    // Check if user is admin
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "thetruthsearchchannel@gmail.com" && request.auth.token.email_verified == true));
    }
    //
    // Validate required fields exist
    function hasRequiredFields(data, fields) {
      return data.keys().hasAll(fields);
    }
    //
    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return hasRequiredFields(data, ['uid', 'displayName', 'totalPoints', 'lastUpdated']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.totalPoints is number && data.totalPoints >= 0 &&
             data.lastUpdated is timestamp &&
             (!('level' in data) || (data.level is number && data.level >= 1)) &&
             (!('role' in data) || (data.role is string && data.role in ['user', 'admin']));
    }

    function isValidDrillAttempt(data) {
      return hasRequiredFields(data, ['uid', 'drillId', 'successRate', 'pointsEarned', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.drillId is string &&
             data.successRate is number && data.successRate >= 0 && data.successRate <= 100 &&
             data.pointsEarned is number && data.pointsEarned >= 0 &&
             data.timestamp is timestamp;
    }

    function isValidQuizResult(data) {
      return hasRequiredFields(data, ['uid', 'score', 'totalQuestions', 'pointsEarned', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.score is number && data.score >= 0 &&
             data.totalQuestions is number && data.totalQuestions > 0 &&
             data.pointsEarned is number && data.pointsEarned >= 0 &&
             data.timestamp is timestamp;
    }

    // Rules
    match /users/{userId} {
      // Allow reading own profile or leaderboard (which only shows public info)
      allow read: if isAuthenticated();
      
      // Allow users to create their own profile
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      
      // Allow users to update their own profile, but not their role (unless admin)
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    (request.resource.data.uid == resource.data.uid) &&
                    (request.resource.data.get('role', resource.data.get('role', 'user')) == resource.data.get('role', 'user') || isAdmin());
    }

    match /drill_attempts/{attemptId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidDrillAttempt(request.resource.data);
      allow update, delete: if isDocOwner() || isAdmin();
    }

    match /quiz_results/{resultId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidQuizResult(request.resource.data);
      allow update, delete: if isDocOwner() || isAdmin();
    }
  }
}
