rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (matches request.auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - totalPoints: number (required, >= 0)
    //   - level: number (optional, >= 1)
    //   - lastUpdated: timestamp (required)
    //
    // Collection: drill_attempts
    // Document ID: attemptId
    // Fields:
    //   - uid: string (required, matches request.auth.uid)
    //   - drillId: string (required)
    //   - successRate: number (required, 0-100)
    //   - pointsEarned: number (required, >= 0)
    //   - isPersonalBest: bool (optional)
    //   - timestamp: timestamp (required)
    //
    // Collection: quiz_results
    // Document ID: resultId
    // Fields:
    //   - uid: string (required, matches request.auth.uid)
    //   - score: number (required, >= 0)
    //   - totalQuestions: number (required, > 0)
    //   - pointsEarned: number (required, >= 0)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'totalPoints', 'lastUpdated']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.totalPoints is number && data.totalPoints >= 0 &&
             data.lastUpdated is timestamp;
    }

    function isValidDrillAttempt(data) {
      return data.keys().hasAll(['uid', 'drillId', 'successRate', 'pointsEarned', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.drillId is string &&
             data.successRate is number && data.successRate >= 0 && data.successRate <= 100 &&
             data.pointsEarned is number && data.pointsEarned >= 0 &&
             data.timestamp is timestamp;
    }

    function isValidQuizResult(data) {
      return data.keys().hasAll(['uid', 'score', 'totalQuestions', 'pointsEarned', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.score is number && data.score >= 0 &&
             data.totalQuestions is number && data.totalQuestions > 0 &&
             data.pointsEarned is number && data.pointsEarned >= 0 &&
             data.timestamp is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid;
    }

    match /drill_attempts/{attemptId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidDrillAttempt(request.resource.data);
      allow update, delete: if isDocOwner();
    }

    match /quiz_results/{resultId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidQuizResult(request.resource.data);
      allow update, delete: if isDocOwner();
    }
  }
}
